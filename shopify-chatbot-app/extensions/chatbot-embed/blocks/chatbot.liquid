{% schema %}
{
  "name": "AI Chatbot",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "Backend API URL",
      "default": "https://shopify-chatbot-ht2e.onrender.com"
    }
  ]
}
{% endschema %}

<script src="https://unpkg.com/axios/dist/axios.min.js" defer></script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
  #ai-chatbot-bubble {
    position: fixed !important; bottom: 24px !important; right: 24px !important;
    width: 56px !important; height: 56px !important; border-radius: 50% !important;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    border: none !important; color: #fff !important; font-size: 24px !important;
    cursor: pointer !important; box-shadow: 0 8px 25px rgba(102,126,234,0.5) !important;
    z-index: 2147483647 !important; transition: transform 0.3s ease, box-shadow 0.3s ease !important;
    display: flex !important; align-items: center !important; justify-content: center !important;
  }
  #ai-chatbot-bubble:hover { transform: scale(1.1) !important; box-shadow: 0 12px 30px rgba(102,126,234,0.6) !important; }
  
  #ai-chatbot-box {
    display: none; position: fixed !important; bottom: 90px !important; right: 24px !important;
    width: 360px !important; height: 520px !important;
    background: #ffffff !important; border-radius: 20px !important;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15) !important;
    flex-direction: column !important; overflow: hidden !important;
    border: 1px solid rgba(255,255,255,0.2) !important;
    z-index: 2147483646 !important; font-family: 'Inter', sans-serif !important;
  }
  #ai-chatbot-box.ai-open { display: flex !important; animation: aiSlideUp 0.3s ease; }
  @keyframes aiSlideUp { from { opacity:0; transform: translateY(20px); } to { opacity:1; transform: translateY(0); } }
  
  #ai-chatbot-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: #fff; padding: 16px 18px; display: flex; align-items: center; gap: 12px;
  }
  #ai-chatbot-header-avatar {
    width: 38px; height: 38px; border-radius: 50%; background: rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;
  }
  #ai-chatbot-header-info { flex: 1; }
  #ai-chatbot-header-name { font-weight: 700; font-size: 14px; }
  #ai-chatbot-header-status { font-size: 11px; opacity: 0.85; display: flex; align-items: center; gap: 4px; margin-top: 2px; }
  #ai-chatbot-header-status::before { content:''; width:6px; height:6px; border-radius:50%; background:#4ade80; display:inline-block; }
  #ai-chatbot-close { cursor: pointer; font-size: 18px; opacity: 0.8; transition: opacity 0.2s; padding: 4px; }
  #ai-chatbot-close:hover { opacity: 1; }
  
  #ai-chatbot-messages {
    flex: 1; overflow-y: auto; padding: 16px; display: flex;
    flex-direction: column; gap: 10px; background: #f8f9ff;
  }
  #ai-chatbot-messages::-webkit-scrollbar { width: 4px; }
  #ai-chatbot-messages::-webkit-scrollbar-track { background: transparent; }
  #ai-chatbot-messages::-webkit-scrollbar-thumb { background: #ddd; border-radius: 4px; }
  
  #ai-chatbot-input-row {
    display: flex; border-top: 1px solid #f0f0f0; padding: 12px 14px;
    gap: 8px; background: #fff; align-items: center;
  }
  #ai-chatbot-input {
    flex: 1; border: 1.5px solid #e8e8f0; border-radius: 12px;
    padding: 9px 14px; font-size: 13px; outline: none; color: #334155;
    font-family: 'Inter', sans-serif; transition: border-color 0.2s; background: #f8f9ff;
  }
  #ai-chatbot-input:focus { border-color: #667eea; background: #fff; }
  #ai-chatbot-send {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: #fff; border: none; border-radius: 12px; padding: 9px 16px;
    cursor: pointer; font-weight: 600; font-size: 13px; font-family: 'Inter', sans-serif;
    transition: opacity 0.2s;
  }
  #ai-chatbot-send:hover { opacity: 0.9; }
  
  .ai-msg-bot {
    align-self: flex-start; background: #fff; color: #334155;
    padding: 10px 14px; border-radius: 16px 16px 16px 4px;
    max-width: 85%; font-size: 13px; line-height: 1.6;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06); border: 1px solid #f0f0f0;
  }
  .ai-msg-user {
    align-self: flex-end; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: #fff; padding: 10px 14px; border-radius: 16px 16px 4px 16px;
    max-width: 85%; font-size: 13px; line-height: 1.6;
    box-shadow: 0 2px 8px rgba(102,126,234,0.3);
  }
  
  .ai-typing {
    align-self: flex-start; background: #fff; padding: 12px 16px;
    border-radius: 16px 16px 16px 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    border: 1px solid #f0f0f0; display: flex; gap: 4px; align-items: center;
  }
  .ai-dot { width: 4px; height: 4px; background: #94a3b8; border-radius: 50%; animation: aiBlink 1.4s infinite; }
  .ai-dot:nth-child(2) { animation-delay: 0.2s; }
  .ai-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes aiBlink { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }

  .ai-product-card {
    background: #fff; border-radius: 12px; overflow: hidden;
    border: 1px solid #eee; margin-top: 8px; width: 100%;
  }
  .ai-product-img { width: 100%; height: 140px; object-fit: cover; }
  .ai-product-info { padding: 10px; }
  .ai-product-title { font-weight: 600; font-size: 13px; margin-bottom: 4px; color: #1e293b; }
  .ai-product-price { color: #667eea; font-weight: 700; font-size: 14px; }
  .ai-product-btn {
    display: block; width: 100%; padding: 8px; background: #f8f9ff;
    text-align: center; color: #667eea; text-decoration: none;
    font-size: 12px; font-weight: 600; border-top: 1px solid #eee;
  }
</style>

<div id="ai-chatbot-widget">
  <button id="ai-chatbot-bubble">💬</button>
  <div id="ai-chatbot-box">
    <div id="ai-chatbot-header">
      <div id="ai-chatbot-header-avatar">🤖</div>
      <div id="ai-chatbot-header-info">
        <div id="ai-chatbot-header-name">Store Assistant</div>
        <div id="ai-chatbot-header-status">Online</div>
      </div>
      <div id="ai-chatbot-close">✕</div>
    </div>
    <div id="ai-chatbot-messages"></div>
    <div id="ai-chatbot-input-row">
      <input type="text" id="ai-chatbot-input" placeholder="Ask anything...">
      <button id="ai-chatbot-send">Send</button>
    </div>
  </div>
</div>

<script>
  (function() {
    var API_URL = "{{ block.settings.api_url }}";
    var open = false;
    var sessionId = "session_" + Math.random().toString(36).substr(2, 9);
    var messages = [{from:"bot", text:"👋 Hi! Welcome to our store! I can help you find products, track orders, check prices and more. What are you looking for?"}];

    var bubble = document.getElementById("ai-chatbot-bubble");
    var box = document.getElementById("ai-chatbot-box");
    var close = document.getElementById("ai-chatbot-close");
    var input = document.getElementById("ai-chatbot-input");
    var send = document.getElementById("ai-chatbot-send");
    var msgContainer = document.getElementById("ai-chatbot-messages");

    function renderMessages() {
      msgContainer.innerHTML = "";
      messages.forEach(function(m) {
        var div = document.createElement("div");
        div.className = m.from === "bot" ? "ai-msg-bot" : "ai-msg-user";
        div.innerText = m.text;
        msgContainer.appendChild(div);

        if (m.products) {
          m.products.forEach(function(p) {
            var pdiv = document.createElement("div");
            pdiv.className = "ai-product-card";
            pdiv.innerHTML = `
              ${p.image ? `<img src="${p.image}" class="ai-product-img">` : ''}
              <div class="ai-product-info">
                <div class="ai-product-title">${p.title}</div>
                <div class="ai-product-price">${p.price}</div>
              </div>
              <a href="${p.url}" class="ai-product-btn" target="_blank">View Product</a>
            `;
            msgContainer.appendChild(pdiv);
          });
        }
      });
      msgContainer.scrollTop = msgContainer.scrollHeight;
    }

    bubble.onclick = function() {
      open = !open;
      box.classList.toggle("ai-open", open);
      if (open) renderMessages();
    };

    close.onclick = function() {
      open = false;
      box.classList.remove("ai-open");
    };

    async function handleSend() {
      var text = input.value.trim();
      if (!text) return;
      input.value = "";
      messages.push({from:"user", text: text});
      renderMessages();

      var typing = document.createElement("div");
      typing.className = "ai-typing";
      typing.innerHTML = '<div class="ai-dot"></div><div class="ai-dot"></div><div class="ai-dot"></div>';
      msgContainer.appendChild(typing);
      msgContainer.scrollTop = msgContainer.scrollHeight;

      async function postChat() {
        return axios.post(API_URL + "/chat", { message: text, session_id: sessionId }, { timeout: 60000 });
      }

      try {
        let res;
        try {
          res = await postChat();
        } catch (e) {
          // Wake up the server and retry once
          try { await axios.get(API_URL + "/", { timeout: 30000 }); } catch(_) {}
          res = await postChat();
        }
        msgContainer.removeChild(typing);

        if (res.data.type === "products") {
          messages.push({from:"bot", text: "I found some products for you:", products: res.data.products});
        } else {
          messages.push({from:"bot", text: res.data.text});
        }
        renderMessages();
      } catch (e) {
        msgContainer.removeChild(typing);
        messages.push({from:"bot", text: "Sorry, I'm having trouble connecting right now. Please try again later!"});
        renderMessages();
      }
    }

    send.onclick = handleSend;
    input.onkeypress = function(e) { if(e.key === "Enter") handleSend(); };
  })();
</script>
